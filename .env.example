# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── Data Service ──────────────────────────────────────────────────────────────
# Full SQLAlchemy connection string for the database
DATABASE_URL=mysql+pymysql://user:password@localhost/pogo_db

# Koji instance (map-area provider)
KOJI_HOST=192.168.0.247
KOJI_PORT=8080
KOJI_TIMEOUT=10

# Port the data service listens on
DATA_SERVICE_PORT=5000

# ── Web App Backend ───────────────────────────────────────────────────────────
# URL where the data service is reachable from the web-app backend
DATA_SERVICE_URL=http://localhost:5000

# Port the web app backend listens on
WEB_APP_PORT=8000

# ── Shared ────────────────────────────────────────────────────────────────────
# Set to true to enable debug mode (never true in production)
DEBUG=false
